# Placeholder only. Do not put real secrets in this file.
# Export real values in your shell before running Ideate.
OPENAI_API_KEY=
IDEATE_MODEL=gpt-4.1-nano
# Optional global tuning override (0.0-2.0)
IDEATE_TEMPERATURE=0.4

# Optional per-stage overrides
# IDEATE_MODEL_RESEARCH=gpt-4.1-mini
# IDEATE_MODEL_DEBATE=gpt-4.1
# IDEATE_MODEL_PLANNING=gpt-4.1-mini

# Optional per-agent overrides (examples)
# IDEATE_MODEL_DEBATE_ADVOCATE=gpt-4.1
# IDEATE_MODEL_DEBATE_SKEPTIC=gpt-4.1-mini
# IDEATE_TEMPERATURE_DEBATE_ADVOCATE=0.9
# IDEATE_TEMPERATURE_DEBATE_SKEPTIC=0.2
# IDEATE_STRICT_DEBATE=1
# IDEATE_REQUIRE_LLM=1
# IDEATE_AGENT_THEME=bihar_jharkhand

# Force deterministic rule-based fallback instead of LLM calls
# IDEATE_FORCE_RULE_BASED=1
AGENTOPS_API_KEY=
# Neon Postgres connection string — leave empty to use local SQLite
DATABASE_URL=

#SMTP_HOST
#SMTP_PORT (optional, defaults to 587)
#SMTP_USER 
#SMTP_PASS 
#IDEATE_EMAIL_FROM
#IDEATE_EMAIL_TO

